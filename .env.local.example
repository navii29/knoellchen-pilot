# ============================================
# KNÖLLCHEN-PILOT — Environment Variables
# Kopiere diese Datei zu .env.local und trage echte Werte ein.
# ============================================

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbG...
SUPABASE_SERVICE_ROLE_KEY=eyJhbG...

# Anthropic Claude API (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=sk-ant-api03-...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Postmark — E-Mail-Automation (postmarkapp.com)
# Server-Token aus Postmark Server Settings → API Tokens
POSTMARK_SERVER_TOKEN=
# Domain für Inbound-Mail (MX-Records in Postmark eingerichtet)
POSTMARK_INBOUND_DOMAIN=knoellchen-pilot.de
# Beliebiger Secret-String — als URL-Query ?token=... an Postmark Webhook-URL anhängen
POSTMARK_WEBHOOK_SECRET=
# Fallback-Absender wenn Org keine eigene sender_email hinterlegt hat
POSTMARK_DEFAULT_SENDER=noreply@knoellchen-pilot.de
